#pragma once
// Wi-Fi 認証情報のテンプレート。
//
// 使い方:
//   1. このファイルを同じ src/ に secrets.h という名前でコピーする
//   2. 下の値を自分の Wi-Fi に書き換える
//
// secrets.h は .gitignore で git 管理外（コミットされない）。
// 認証情報はファームウェアにのみ存在し、リポジトリには一切含めない。

#define WIFI_SSID "your-ssid"
#define WIFI_PASS "your-password"

// 中継サーバ(②-2b)の /chat エンドポイント。
// ローカル実行時は中継サーバを動かす PC の LAN IP を指す（例: 192.168.1.10:3000）。
#define RELAY_URL "http://192.168.1.10:3000/chat"
